.Rproj.user
.Rhistory
.RData
.Ruserdata

# Native build artifacts (including nested src/c and src/cpp)
*.o
*.so
*.dll
src/**/*.o
src/**/*.so
src/**/*.dll

# Vignette build output
vignettes/*.png
vignettes/*.Rmd

# Smoke-test outputs from example/run_*.R
example/out_*/

# testthat side-effects: every analysis stage writes .qs / .csv / .png /
# .RData / .mat / .rds files into the CWD where the test runs (which is
# tests/testthat itself). The fixtures we keep are under testdata/.
tests/testthat/*.qs
tests/testthat/*.csv
tests/testthat/*.png
tests/testthat/*.RData
tests/testthat/*.mat
tests/testthat/*.rds
!tests/testthat/testdata/
